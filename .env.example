ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=set-a-strong-password-here
# SQLite file path (local default: ./lucky_susu.db). On Railway use a mounted volume:
# DATABASE_PATH=/data/lucky_susu.db
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=24h
ALLOWED_ORIGINS=https://your-frontend-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTO_OPEN_BROWSER=false
SYSTEM_API_KEY=replace-with-your-sms-api-key
SMS_API_URL=https://sms.arkesel.com/api/v2/sms/send
SMS_SENDER_ID=LuckySusu
ARKESEL_WEBHOOK_SECRET=replace-with-random-webhook-secret
